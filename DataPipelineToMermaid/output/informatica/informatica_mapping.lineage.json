  "components": [
    {
      "name": "SQ_TRANSACTIONS",
      "component_type": "transformation",
      "description": "Filters transaction data to exclude cancelled and fraudulent transactions, and only includes transactions from the last day. Applies business rule: TXN_STATUS NOT IN ('CANCELLED', 'FRAUDULENT') AND TXN_DATE >= TRUNC(SYSDATE) - 1",
      "input_tables": [
        "SRC_SALES.TRANSACTIONS"
      ],
      "output_columns": [
        "TXN_ID",
        "CUSTOMER_ID",
        "STORE_ID",
        "TXN_DATE",
        "TOTAL_AMT",
        "DISCOUNT_AMT",
        "TAX_AMT",
        "PAYMENT_METHOD",
        "CHANNEL",
        "CURRENCY_CD",
        "TXN_STATUS"
      ],
      "sql_text": "SELECT TXN_ID, CUSTOMER_ID, STORE_ID, TXN_DATE, TOTAL_AMT, DISCOUNT_AMT, TAX_AMT, PAYMENT_METHOD, CHANNEL, CURRENCY_CD, TXN_STATUS FROM SRC_SALES.TRANSACTIONS WHERE TXN_STATUS NOT IN ('CANCELLED', 'FRAUDULENT') AND TXN_DATE >= TRUNC(SYSDATE) - 1"
    },
    {
      "name": "SQ_TRANSACTION_DETAILS",
      "component_type": "transformation",
      "description": "Source qualifier for transaction detail records, passes through all line item data without filtering",
      "input_tables": [
        "SRC_SALES.TRANSACTION_DETAILS"
      ],
      "output_columns": [
        "DETAIL_ID",
        "TXN_ID",
        "PRODUCT_ID",
        "QUANTITY",
        "UNIT_PRICE",
        "LINE_TOTAL"
      ],
      "sql_text": "SELECT DETAIL_ID, TXN_ID, PRODUCT_ID, QUANTITY, UNIT_PRICE, LINE_TOTAL FROM SRC_SALES.TRANSACTION_DETAILS"
    },
    {
      "name": "JNR_TXN_DETAILS",
      "component_type": "transformation",
      "description": "Inner joins transaction headers with transaction details on TXN_ID to combine header-level information (customer, store, payment method) with line-level information (product, quantity, pricing)",
      "input_tables": [
        "SQ_TRANSACTIONS",
        "SQ_TRANSACTION_DETAILS"
      ],
      "output_columns": [
        "TXN_ID",
        "CUSTOMER_ID",
        "STORE_ID",
        "TXN_DATE",
        "TOTAL_AMT",
        "DISCOUNT_AMT",
        "TAX_AMT",
        "PAYMENT_METHOD",
        "CHANNEL",
        "CURRENCY_CD",
        "DETAIL_ID",
        "PRODUCT_ID",
        "QUANTITY",
        "UNIT_PRICE",
        "LINE_TOTAL"
      ],
      "sql_text": "Normal Join: SQ_TRANSACTIONS.TXN_ID = SQ_TRANSACTION_DETAILS.TXN_ID"
    },
    {
      "name": "LKP_PRODUCT_MASTER",
      "component_type": "transformation",
      "description": "Looks up product information including category and calculates margin percentage as (UNIT_PRICE - COST_PRICE) / NULLIF(UNIT_PRICE, 0) * 100. Only returns active products (IS_ACTIVE = 1)",
      "input_tables": [
        "REF_DATA.PRODUCT_MASTER"
      ],
      "output_columns": [
        "PRODUCT_NAME",
        "CATEGORY",
        "COST_PRICE",
        "MARGIN_PCT"
      ],
      "sql_text": "SELECT PRODUCT_ID, PRODUCT_NAME, CATEGORY, COST_PRICE, (UNIT_PRICE - COST_PRICE) / NULLIF(UNIT_PRICE, 0) * 100 AS MARGIN_PCT FROM REF_DATA.PRODUCT_MASTER WHERE IS_ACTIVE = 1"
    },
    {
      "name": "LKP_STORE_MASTER",
      "component_type": "transformation",
      "description": "Looks up store information to get surrogate key and region for dimensional modeling",
      "input_tables": [
        "REF_DATA.STORE_MASTER"
      ],
      "output_columns": [
        "STORE_SK",
        "STORE_REGION",
        "STORE_NAME"
      ],
      "sql_text": "Lookup condition: IN_STORE_ID = STORE_ID"
    },
    {
      "name": "EXP_CURRENCY_CALC",
      "component_type": "transformation",
      "description": "Converts all monetary amounts to USD using exchange rate lookup, calculates net amount as line total minus discount plus tax, derives date surrogate key from transaction date, and assigns margin bands: High (≥50%), Medium (≥25%), Low (≥0%), Negative (<0%)",
      "input_tables": [
        "JNR_TXN_DETAILS",
        "LKP_PRODUCT_MASTER",
        "LKP_STORE_MASTER"
      ],
      "output_columns": [
        "TXN_ID",
        "CUSTOMER_ID",
        "STORE_SK",
        "TXN_DATE",
        "PRODUCT_ID",
        "QUANTITY",
        "PAYMENT_METHOD",
        "CHANNEL",
        "CATEGORY",
        "STORE_REGION",
        "O_UNIT_PRICE_USD",
        "O_LINE_TOTAL_USD",
        "O_DISCOUNT_USD",
        "O_TAX_USD",
        "O_NET_AMOUNT_USD",
        "O_DATE_SK",
        "O_MARGIN_BAND"
      ],
      "sql_text": "O_UNIT_PRICE_USD = IIF(CURRENCY_CD = 'USD', UNIT_PRICE, UNIT_PRICE * :LKP.RETURN(LKP_FX_RATE, CURRENCY_CD, 'USD')); O_NET_AMOUNT_USD = O_LINE_TOTAL_USD - O_DISCOUNT_USD + O_TAX_USD; O_MARGIN_BAND = IIF(MARGIN_PCT >= 50, 'High', IIF(MARGIN_PCT >= 25, 'Medium', IIF(MARGIN_PCT >= 0, 'Low', 'Negative')))"
    },
    {
      "name": "SEQ_SALES_SK",
      "component_type": "transformation",
      "description": "Generates sequential surrogate keys for the sales fact table starting from 1, incrementing by 1, with maximum value of 9999999999",
      "input_tables": [],
      "output_columns": [
        "NEXTVAL",
        "CURRVAL"
      ],
      "sql_text": "Start Value: 1, Increment By: 1, End Value: 9999999999, Cycle: NO"
    },
    {
      "name": "RTR_VALIDATION",
      "component_type": "transformation",
      "description": "Routes records into valid and invalid groups. Valid records must have non-null CUSTOMER_ID and PRODUCT_ID, positive net amount USD, and positive quantity. Invalid records are routed to default group for error handling",
      "input_tables": [
        "EXP_CURRENCY_CALC"
      ],
      "output_columns": [
        "TXN_ID",
        "CUSTOMER_ID",
        "PRODUCT_ID",
        "STORE_SK",
        "O_DATE_SK",
        "QUANTITY",
        "O_UNIT_PRICE_USD",
        "O_LINE_TOTAL_USD",
        "O_DISCOUNT_USD",
        "O_TAX_USD",
        "O_NET_AMOUNT_USD",
        "PAYMENT_METHOD",
        "CHANNEL",
        "CATEGORY",
        "STORE_REGION",
        "O_MARGIN_BAND"
      ],
      "sql_text": "VALID_RECORDS: NOT ISNULL(CUSTOMER_ID) AND NOT ISNULL(PRODUCT_ID) AND O_NET_AMOUNT_USD > 0 AND QUANTITY > 0; INVALID_RECORDS: DEFAULT"
    }
  ],
