        {"name": "category", "data_type": "VARCHAR(100)", "description": "Product category"}
      ],
      "table_type": "source"
    }
  ],
  "targets": [
    {
      "schema_name": "analytics",
      "table_name": "customer_summary",
      "columns": [
        {"name": "customer_id", "data_type": "INT", "description": "Customer identifier"},
        {"name": "customer_name", "data_type": "VARCHAR(201)", "description": "Full name"},
        {"name": "email", "data_type": "VARCHAR(255)", "description": "Email"},
        {"name": "region", "data_type": "VARCHAR(50)", "description": "Region"},
