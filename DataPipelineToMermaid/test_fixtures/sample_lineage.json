      "table_type": "target"
    }
  ],
  "components": [
    {
      "name": "cte_active_customers",
      "component_type": "CTE",
      "description": "Filters to only active customers",
      "input_tables": ["sales.customers"],
      "output_columns": ["customer_id", "first_name", "last_name", "email", "signup_date", "region"],
      "sql_text": "SELECT customer_id, first_name, last_name, email, signup_date, region FROM sales.customers WHERE status = 'active'"
    },
    {
      "name": "cte_order_stats",
      "component_type": "CTE",
      "description": "Aggregates order statistics per customer",
      "input_tables": ["sales.orders"],
      "output_columns": ["customer_id", "total_orders", "total_revenue", "avg_order_value"],
      "sql_text": "SELECT customer_id, COUNT(*) as total_orders, SUM(total_amount) as total_revenue, AVG(total_amount) as avg_order_value FROM sales.orders GROUP BY customer_id"
    },
    {
      "name": "cte_top_category",
      "component_type": "CTE",
      "description": "Finds the top product category for each customer using ROW_NUMBER",
      "input_tables": ["sales.order_items", "sales.orders", "products.products"],
      "output_columns": ["customer_id", "category", "rn"],
      "sql_text": "SELECT o.customer_id, p.category, ROW_NUMBER() OVER (PARTITION BY o.customer_id ORDER BY COUNT(*) DESC) as rn ..."
    },
    {
      "name": "cte_customer_tier",
      "component_type": "CTE",
      "description": "Assigns tier based on total revenue using CASE",
      "input_tables": ["cte_order_stats"],
      "output_columns": ["customer_id", "customer_tier"],
      "sql_text": "SELECT customer_id, CASE WHEN total_revenue > 10000 THEN 'gold' WHEN total_revenue > 5000 THEN 'silver' ELSE 'bronze' END as customer_tier ..."
    }
  ],
