        {"source_table": "sales.order_items", "source_column": "product_id"},
        {"source_table": "sales.orders", "source_column": "customer_id"}
      ],
      "transformation": "FIRST_VALUE(p.category) OVER (PARTITION BY o.customer_id ORDER BY COUNT(*) DESC) AS top_category",
      "transformation_type": "window_function",
      "intermediate_steps": [
