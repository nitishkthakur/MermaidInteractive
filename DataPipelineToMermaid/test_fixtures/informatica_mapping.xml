<?xml version="1.0" encoding="UTF-8"?>
<!--
  Informatica PowerCenter Mapping Definition
  ===========================================
  Sales Data Warehouse Load — Mapping: m_Sales_Fact_Load
  
  Reads from two source qualifiers (Oracle), passes through
  Expression transforms, Lookup, Aggregator, Router, Sequence Generator,
  Joiner, and loads into a target data warehouse table.
  
  Source tables:
    - SRC_SALES.TRANSACTIONS
    - SRC_SALES.TRANSACTION_DETAILS
    - REF_DATA.PRODUCT_MASTER
    - REF_DATA.STORE_MASTER
  
  Target table:
    - DWH.FACT_SALES
    - DWH.DIM_DATE (SCD Type 1 update)
-->
<POWERMART CREATION_DATE="2024-01-15 10:30:00"
           REPOSITORY_VERSION="186.95">

<REPOSITORY NAME="PROD_REP" VERSION="186" CODEPAGE="UTF-8"
            DATABASETYPE="Oracle">

<FOLDER NAME="Sales_ETL" GROUP="" OWNER="admin"
        SHARED="NOTSHARED" DESCRIPTION="Sales data warehouse ETL"
        PERMISSIONS="rwxr-xr-x" UUID="a1b2c3d4">

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- SOURCE DEFINITIONS                                             -->
<!-- ═══════════════════════════════════════════════════════════════ -->

<SOURCE BUSINESSNAME="Sales Transactions" DATABASETYPE="Oracle"
        DBDNAME="SRC_SALES" DESCRIPTION="Transaction header table"
        NAME="TRANSACTIONS" OBJECTVERSION="1" OWNERNAME="SRC_SALES"
        VERSIONNUMBER="1">
  <SOURCEFIELD BUSINESSNAME="Transaction ID" DATATYPE="number"
               FIELDNUMBER="1" FIELDTYPE="ELEMITEM" KEYTYPE="PRIMARY KEY"
               NAME="TXN_ID" NULLABLE="NOTNULL" PICTURETEXT=""
               PRECISION="12" SCALE="0" USAGE_FLAGS=""/>
  <SOURCEFIELD BUSINESSNAME="Customer ID" DATATYPE="number"
               FIELDNUMBER="2" NAME="CUSTOMER_ID" NULLABLE="NULL"
               PRECISION="12" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="Store ID" DATATYPE="number"
               FIELDNUMBER="3" NAME="STORE_ID" NULLABLE="NULL"
               PRECISION="8" SCALE="0"/>
  <SOURCEFIELD BUSINESSNAME="Transaction Date" DATATYPE="date/time"
               FIELDNUMBER="4" NAME="TXN_DATE" NULLABLE="NULL"/>
  <SOURCEFIELD BUSINESSNAME="Total Amount" DATATYPE="number"
               FIELDNUMBER="5" NAME="TOTAL_AMT" NULLABLE="NULL"
               PRECISION="14" SCALE="2"/>
  <SOURCEFIELD BUSINESSNAME="Discount Amount" DATATYPE="number"
               FIELDNUMBER="6" NAME="DISCOUNT_AMT" NULLABLE="NULL"
               PRECISION="10" SCALE="2"/>
  <SOURCEFIELD BUSINESSNAME="Tax Amount" DATATYPE="number"
               FIELDNUMBER="7" NAME="TAX_AMT" NULLABLE="NULL"
               PRECISION="10" SCALE="2"/>
  <SOURCEFIELD BUSINESSNAME="Payment Method" DATATYPE="varchar2"
               FIELDNUMBER="8" NAME="PAYMENT_METHOD" NULLABLE="NULL"
               PRECISION="30"/>
  <SOURCEFIELD BUSINESSNAME="Channel" DATATYPE="varchar2"
               FIELDNUMBER="9" NAME="CHANNEL" NULLABLE="NULL"
               PRECISION="20"/>
  <SOURCEFIELD BUSINESSNAME="Currency Code" DATATYPE="varchar2"
               FIELDNUMBER="10" NAME="CURRENCY_CD" NULLABLE="NULL"
               PRECISION="3"/>
  <SOURCEFIELD BUSINESSNAME="Transaction Status" DATATYPE="varchar2"
               FIELDNUMBER="11" NAME="TXN_STATUS" NULLABLE="NULL"
               PRECISION="20"/>
</SOURCE>

<SOURCE BUSINESSNAME="Transaction Details" DATABASETYPE="Oracle"
        DBDNAME="SRC_SALES" NAME="TRANSACTION_DETAILS"
        OWNERNAME="SRC_SALES">
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY"
               NAME="DETAIL_ID" NULLABLE="NOTNULL" PRECISION="15"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="2" NAME="TXN_ID"
               NULLABLE="NOTNULL" PRECISION="12" SCALE="0"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="3" NAME="PRODUCT_ID"
               NULLABLE="NULL" PRECISION="10"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="4" NAME="QUANTITY"
               NULLABLE="NULL" PRECISION="8"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="5" NAME="UNIT_PRICE"
               NULLABLE="NULL" PRECISION="10" SCALE="2"/>
  <SOURCEFIELD DATATYPE="number" FIELDNUMBER="6" NAME="LINE_TOTAL"
               NULLABLE="NULL" PRECISION="12" SCALE="2"/>
</SOURCE>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- TARGET DEFINITION                                              -->
<!-- ═══════════════════════════════════════════════════════════════ -->

<TARGET BUSINESSNAME="Sales Fact Table" DATABASETYPE="Oracle"
        DBDNAME="DWH" DESCRIPTION="Fact table for sales analysis"
        NAME="FACT_SALES" OBJECTVERSION="1" TABLEOPTIONS=""
        VERSIONNUMBER="1">
  <TARGETFIELD BUSINESSNAME="Surrogate Key" DATATYPE="number"
               FIELDNUMBER="1" KEYTYPE="PRIMARY KEY"
               NAME="SALES_SK" NULLABLE="NOTNULL" PRECISION="15"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="2" NAME="TXN_ID"
               NULLABLE="NOTNULL" PRECISION="12"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="3" NAME="CUSTOMER_ID"
               NULLABLE="NULL" PRECISION="12"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="4" NAME="PRODUCT_ID"
               NULLABLE="NULL" PRECISION="10"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="5" NAME="STORE_SK"
               NULLABLE="NULL" PRECISION="10"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="6" NAME="DATE_SK"
               NULLABLE="NULL" PRECISION="8"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="7" NAME="QUANTITY"
               NULLABLE="NULL" PRECISION="8"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="8" NAME="UNIT_PRICE_USD"
               NULLABLE="NULL" PRECISION="10" SCALE="2"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="9" NAME="LINE_TOTAL_USD"
               NULLABLE="NULL" PRECISION="12" SCALE="2"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="10" NAME="DISCOUNT_USD"
               NULLABLE="NULL" PRECISION="10" SCALE="2"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="11" NAME="TAX_USD"
               NULLABLE="NULL" PRECISION="10" SCALE="2"/>
  <TARGETFIELD DATATYPE="number" FIELDNUMBER="12" NAME="NET_AMOUNT_USD"
               NULLABLE="NULL" PRECISION="14" SCALE="2"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="13" NAME="PAYMENT_METHOD"
               NULLABLE="NULL" PRECISION="30"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="14" NAME="CHANNEL"
               NULLABLE="NULL" PRECISION="20"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="15" NAME="PRODUCT_CATEGORY"
               NULLABLE="NULL" PRECISION="100"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="16" NAME="STORE_REGION"
               NULLABLE="NULL" PRECISION="50"/>
  <TARGETFIELD DATATYPE="varchar2" FIELDNUMBER="17" NAME="MARGIN_BAND"
               NULLABLE="NULL" PRECISION="20"/>
  <TARGETFIELD DATATYPE="date/time" FIELDNUMBER="18" NAME="LOAD_DATE"/>
</TARGET>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- MAPPING DEFINITION                                             -->
<!-- ═══════════════════════════════════════════════════════════════ -->

<MAPPING DESCRIPTION="Load sales fact table from transactional sources"
         ISVALID="YES" NAME="m_Sales_Fact_Load" OBJECTVERSION="1"
         VERSIONNUMBER="3">

  <!-- Source Qualifier: Transactions -->
  <TRANSFORMATION DESCRIPTION="Source Qualifier for Transactions"
                  NAME="SQ_TRANSACTIONS" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Source Qualifier"
                  VERSIONNUMBER="1">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="12" SCALE="0"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="12"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="STORE_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="8"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TOTAL_AMT" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="14" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="DISCOUNT_AMT" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="10" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TAX_AMT" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="10" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="PAYMENT_METHOD" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="30"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="20"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CURRENCY_CD" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="3"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="TXN_STATUS" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="20"/>
    <TABLEATTRIBUTE NAME="Sql Query" VALUE="
      SELECT TXN_ID, CUSTOMER_ID, STORE_ID, TXN_DATE,
             TOTAL_AMT, DISCOUNT_AMT, TAX_AMT,
             PAYMENT_METHOD, CHANNEL, CURRENCY_CD, TXN_STATUS
      FROM SRC_SALES.TRANSACTIONS
      WHERE TXN_STATUS NOT IN ('CANCELLED', 'FRAUDULENT')
        AND TXN_DATE >= TRUNC(SYSDATE) - 1"/>
  </TRANSFORMATION>

  <!-- Source Qualifier: Transaction Details -->
  <TRANSFORMATION DESCRIPTION="Source Qualifier for Transaction Details"
                  NAME="SQ_TRANSACTION_DETAILS" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Source Qualifier">
    <TRANSFORMFIELD DATATYPE="number" NAME="DETAIL_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="15"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="12"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="10"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QUANTITY" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="8"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="UNIT_PRICE" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="10" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="LINE_TOTAL" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="12" SCALE="2"/>
  </TRANSFORMATION>

  <!-- Joiner: Join Transactions with Details on TXN_ID -->
  <TRANSFORMATION DESCRIPTION="Join headers with line items"
                  NAME="JNR_TXN_DETAILS" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Joiner">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT"
                    PRECISION="12"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="STORE_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TOTAL_AMT" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="DISCOUNT_AMT" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TAX_AMT" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="PAYMENT_METHOD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CURRENCY_CD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="DETAIL_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QUANTITY" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="UNIT_PRICE" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="LINE_TOTAL" PORTTYPE="INPUT/OUTPUT"/>
    <TABLEATTRIBUTE NAME="Join Type" VALUE="Normal Join"/>
    <TABLEATTRIBUTE NAME="Join Condition" VALUE="SQ_TRANSACTIONS.TXN_ID = SQ_TRANSACTION_DETAILS.TXN_ID"/>
  </TRANSFORMATION>

  <!-- Lookup: Product Master for category & margin -->
  <TRANSFORMATION DESCRIPTION="Lookup product category and margin info"
                  NAME="LKP_PRODUCT_MASTER" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Lookup Procedure">
    <TRANSFORMFIELD DATATYPE="number" NAME="IN_PRODUCT_ID" PORTTYPE="INPUT"
                    PRECISION="10"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="PRODUCT_NAME" PORTTYPE="OUTPUT"
                    PRECISION="200"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CATEGORY" PORTTYPE="OUTPUT"
                    PRECISION="100"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="COST_PRICE" PORTTYPE="OUTPUT"
                    PRECISION="10" SCALE="2"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="MARGIN_PCT" PORTTYPE="OUTPUT"
                    PRECISION="5" SCALE="2"/>
    <TABLEATTRIBUTE NAME="Lookup table name" VALUE="REF_DATA.PRODUCT_MASTER"/>
    <TABLEATTRIBUTE NAME="Lookup Sql Override" VALUE="
      SELECT PRODUCT_ID, PRODUCT_NAME, CATEGORY, COST_PRICE,
             (UNIT_PRICE - COST_PRICE) / NULLIF(UNIT_PRICE, 0) * 100 AS MARGIN_PCT
      FROM REF_DATA.PRODUCT_MASTER
      WHERE IS_ACTIVE = 1"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="IN_PRODUCT_ID = PRODUCT_ID"/>
  </TRANSFORMATION>

  <!-- Lookup: Store Master for region -->
  <TRANSFORMATION DESCRIPTION="Lookup store region"
                  NAME="LKP_STORE_MASTER" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Lookup Procedure">
    <TRANSFORMFIELD DATATYPE="number" NAME="IN_STORE_ID" PORTTYPE="INPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="STORE_SK" PORTTYPE="OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="STORE_REGION" PORTTYPE="OUTPUT"
                    PRECISION="50"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="STORE_NAME" PORTTYPE="OUTPUT"
                    PRECISION="100"/>
    <TABLEATTRIBUTE NAME="Lookup table name" VALUE="REF_DATA.STORE_MASTER"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="IN_STORE_ID = STORE_ID"/>
  </TRANSFORMATION>

  <!-- Expression: Currency conversion & derived columns -->
  <TRANSFORMATION DESCRIPTION="Calculate USD amounts and derived fields"
                  NAME="EXP_CURRENCY_CALC" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Expression">
    <TRANSFORMFIELD DATATYPE="number" NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="STORE_SK" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="date/time" NAME="TXN_DATE" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="QUANTITY" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="UNIT_PRICE" PORTTYPE="INPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CURRENCY_CD" PORTTYPE="INPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="LINE_TOTAL" PORTTYPE="INPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="DISCOUNT_AMT" PORTTYPE="INPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="TAX_AMT" PORTTYPE="INPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="PAYMENT_METHOD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="CATEGORY" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="STORE_REGION" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="MARGIN_PCT" PORTTYPE="INPUT"/>
    <!-- Output ports (calculated) -->
    <TRANSFORMFIELD DATATYPE="number" NAME="O_UNIT_PRICE_USD" PORTTYPE="OUTPUT"
                    PRECISION="10" SCALE="2"
                    EXPRESSION="IIF(CURRENCY_CD = 'USD', UNIT_PRICE,
                                   UNIT_PRICE * :LKP.RETURN(LKP_FX_RATE, CURRENCY_CD, 'USD'))"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="O_LINE_TOTAL_USD" PORTTYPE="OUTPUT"
                    PRECISION="12" SCALE="2"
                    EXPRESSION="IIF(CURRENCY_CD = 'USD', LINE_TOTAL,
                                   LINE_TOTAL * :LKP.RETURN(LKP_FX_RATE, CURRENCY_CD, 'USD'))"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="O_DISCOUNT_USD" PORTTYPE="OUTPUT"
                    PRECISION="10" SCALE="2"
                    EXPRESSION="IIF(CURRENCY_CD = 'USD', DISCOUNT_AMT,
                                   DISCOUNT_AMT * :LKP.RETURN(LKP_FX_RATE, CURRENCY_CD, 'USD'))"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="O_TAX_USD" PORTTYPE="OUTPUT"
                    PRECISION="10" SCALE="2"
                    EXPRESSION="IIF(CURRENCY_CD = 'USD', TAX_AMT,
                                   TAX_AMT * :LKP.RETURN(LKP_FX_RATE, CURRENCY_CD, 'USD'))"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="O_NET_AMOUNT_USD" PORTTYPE="OUTPUT"
                    PRECISION="14" SCALE="2"
                    EXPRESSION="O_LINE_TOTAL_USD - O_DISCOUNT_USD + O_TAX_USD"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="O_DATE_SK" PORTTYPE="OUTPUT"
                    PRECISION="8"
                    EXPRESSION="TO_CHAR(TXN_DATE, 'YYYYMMDD')"/>
    <TRANSFORMFIELD DATATYPE="varchar2" NAME="O_MARGIN_BAND" PORTTYPE="OUTPUT"
                    PRECISION="20"
                    EXPRESSION="IIF(MARGIN_PCT >= 50, 'High',
                                IIF(MARGIN_PCT >= 25, 'Medium',
                                IIF(MARGIN_PCT >= 0, 'Low', 'Negative')))"/>
  </TRANSFORMATION>

  <!-- Sequence Generator: Surrogate Key -->
  <TRANSFORMATION DESCRIPTION="Generate surrogate key for FACT_SALES"
                  NAME="SEQ_SALES_SK" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Sequence Generator">
    <TRANSFORMFIELD DATATYPE="number" NAME="NEXTVAL" PORTTYPE="OUTPUT"
                    PRECISION="15"/>
    <TRANSFORMFIELD DATATYPE="number" NAME="CURRVAL" PORTTYPE="OUTPUT"
                    PRECISION="15"/>
    <TABLEATTRIBUTE NAME="Start Value" VALUE="1"/>
    <TABLEATTRIBUTE NAME="Increment By" VALUE="1"/>
    <TABLEATTRIBUTE NAME="End Value" VALUE="9999999999"/>
    <TABLEATTRIBUTE NAME="Cycle" VALUE="NO"/>
  </TRANSFORMATION>

  <!-- Router: Split valid/invalid records -->
  <TRANSFORMATION DESCRIPTION="Route valid vs. invalid records"
                  NAME="RTR_VALIDATION" OBJECTVERSION="1"
                  REUSABLE="NO" TYPE="Router">
    <TRANSFORMFIELD NAME="TXN_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="PRODUCT_ID" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="STORE_SK" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_DATE_SK" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="QUANTITY" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_UNIT_PRICE_USD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_LINE_TOTAL_USD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_DISCOUNT_USD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_TAX_USD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_NET_AMOUNT_USD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="PAYMENT_METHOD" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="CHANNEL" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="CATEGORY" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="STORE_REGION" PORTTYPE="INPUT/OUTPUT"/>
    <TRANSFORMFIELD NAME="O_MARGIN_BAND" PORTTYPE="INPUT/OUTPUT"/>
    <GROUP NAME="VALID_RECORDS" DESCRIPTION="Records passing validation"
           EXPRESSION="NOT ISNULL(CUSTOMER_ID)
                       AND NOT ISNULL(PRODUCT_ID)
                       AND O_NET_AMOUNT_USD > 0
                       AND QUANTITY > 0"/>
    <GROUP NAME="INVALID_RECORDS" DESCRIPTION="Records failing validation"
           EXPRESSION="DEFAULT"/>
  </TRANSFORMATION>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- CONNECTORS (Data flow wiring)                                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->

  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="TXN_ID"
             TOINSTANCE="SQ_TRANSACTIONS" TOFIELD="TXN_ID"/>
  <CONNECTOR FROMINSTANCE="TRANSACTION_DETAILS" FROMFIELD="TXN_ID"
             TOINSTANCE="SQ_TRANSACTION_DETAILS" TOFIELD="TXN_ID"/>

  <CONNECTOR FROMINSTANCE="SQ_TRANSACTIONS" FROMFIELD="TXN_ID"
             TOINSTANCE="JNR_TXN_DETAILS" TOFIELD="TXN_ID"/>
  <CONNECTOR FROMINSTANCE="SQ_TRANSACTION_DETAILS" FROMFIELD="TXN_ID"
             TOINSTANCE="JNR_TXN_DETAILS" TOFIELD="TXN_ID"/>

  <CONNECTOR FROMINSTANCE="JNR_TXN_DETAILS" FROMFIELD="PRODUCT_ID"
             TOINSTANCE="LKP_PRODUCT_MASTER" TOFIELD="IN_PRODUCT_ID"/>
  <CONNECTOR FROMINSTANCE="JNR_TXN_DETAILS" FROMFIELD="STORE_ID"
             TOINSTANCE="LKP_STORE_MASTER" TOFIELD="IN_STORE_ID"/>

  <CONNECTOR FROMINSTANCE="JNR_TXN_DETAILS" FROMFIELD="TXN_ID"
             TOINSTANCE="EXP_CURRENCY_CALC" TOFIELD="TXN_ID"/>
  <CONNECTOR FROMINSTANCE="LKP_PRODUCT_MASTER" FROMFIELD="CATEGORY"
             TOINSTANCE="EXP_CURRENCY_CALC" TOFIELD="CATEGORY"/>
  <CONNECTOR FROMINSTANCE="LKP_PRODUCT_MASTER" FROMFIELD="MARGIN_PCT"
             TOINSTANCE="EXP_CURRENCY_CALC" TOFIELD="MARGIN_PCT"/>
  <CONNECTOR FROMINSTANCE="LKP_STORE_MASTER" FROMFIELD="STORE_SK"
             TOINSTANCE="EXP_CURRENCY_CALC" TOFIELD="STORE_SK"/>
  <CONNECTOR FROMINSTANCE="LKP_STORE_MASTER" FROMFIELD="STORE_REGION"
             TOINSTANCE="EXP_CURRENCY_CALC" TOFIELD="STORE_REGION"/>

  <CONNECTOR FROMINSTANCE="EXP_CURRENCY_CALC" FROMFIELD="O_NET_AMOUNT_USD"
             TOINSTANCE="RTR_VALIDATION" TOFIELD="O_NET_AMOUNT_USD"/>

  <CONNECTOR FROMINSTANCE="SEQ_SALES_SK" FROMFIELD="NEXTVAL"
             TOINSTANCE="FACT_SALES" TOFIELD="SALES_SK"/>
  <CONNECTOR FROMINSTANCE="RTR_VALIDATION" FROMFIELD="TXN_ID"
             FROMINSTANCEGROUP="VALID_RECORDS"
             TOINSTANCE="FACT_SALES" TOFIELD="TXN_ID"/>

</MAPPING>

</FOLDER>
</REPOSITORY>
</POWERMART>
