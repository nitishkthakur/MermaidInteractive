# ──────────────────────────────────────────────────────────────────────
# DataPipelineToMermaid — Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials:
#   cp .env.template .env
# ──────────────────────────────────────────────────────────────────────

# OpenRouter API key (required)
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# LLM model to use via OpenRouter (optional, defaults shown)
# Examples:
#   anthropic/claude-sonnet-4       (recommended — best quality/cost)
#   anthropic/claude-sonnet-4.5     (extended thinking)
#   openai/gpt-4.1                  (alternative)
#   google/gemini-2.5-pro           (alternative)
#   deepseek/deepseek-r1            (budget option)
LLM_MODEL=anthropic/claude-sonnet-4

# Max tokens for LLM response (optional, default 16384)
# Increase for very large pipelines with many columns
LLM_MAX_TOKENS=32768

# Temperature (optional, default 0 for deterministic output)
LLM_TEMPERATURE=0

# Optional: LangSmith tracing for debugging agent behaviour
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
